generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  avatarUrl     String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  transactions     Transaction[]
  investments      Investment[]
  conversations    Conversation[]
  connections      ProviderConnection[]
  goals            Goal[]
  subscriptions    Subscription[]
  userPlan         UserPlan?
  clients          Client[]
  products         Product[]
  appointments     Appointment[]
  sales            Sale[]
  businessProfile  BusinessProfile?
  financialImports FinancialImport[]
  financialEntries FinancialEntry[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  type        TransactionType
  category    String
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @default("ARS")
  description String
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, type])
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model Investment {
  id           String           @id @default(cuid())
  userId       String
  name         String
  type         InvestmentType
  symbol       String?
  amount       Decimal          @db.Decimal(12, 2)
  quantity     Decimal?         @db.Decimal(16, 8)
  buyPrice     Decimal          @db.Decimal(12, 2)
  currentPrice Decimal?         @db.Decimal(12, 2)
  currency     String           @default("ARS")
  status       InvestmentStatus @default(ACTIVE)
  notes        String?          @db.Text
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

enum InvestmentType {
  STOCK
  CRYPTO
  BOND
  FIXED_TERM
  MUTUAL_FUND
  REAL_ESTATE
  OTHER
}

enum InvestmentStatus {
  ACTIVE
  SOLD
  PENDING
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model ProviderConnection {
  id            String           @id @default(cuid())
  userId        String
  providerId    String
  providerType  ProviderType
  label         String
  status        ConnectionStatus @default(PENDING)
  credentials   String           @db.Text
  institutionId String?
  lastSyncAt    DateTime?
  lastError     String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncLogs SyncLog[]

  @@index([userId, providerId])
  @@index([userId, status])
}

enum ProviderType {
  BANK
  BROKER
  CRYPTO
}

enum ConnectionStatus {
  ACTIVE
  PENDING
  ERROR
  EXPIRED
  DISCONNECTED
}

model SyncLog {
  id                   String     @id @default(cuid())
  connectionId         String
  status               SyncStatus
  transactionsImported Int        @default(0)
  investmentsImported  Int        @default(0)
  accountsImported     Int        @default(0)
  errorMessage         String?    @db.Text
  duration             Int?
  createdAt            DateTime   @default(now())

  connection ProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt])
}

enum SyncStatus {
  SUCCESS
  ERROR
  PARTIAL
}

model Goal {
  id        String    @id @default(cuid())
  userId    String
  name      String
  icon      String    @default("🎯")
  target    Decimal   @db.Decimal(12, 2)
  current   Decimal   @default(0) @db.Decimal(12, 2)
  currency  String    @default("ARS")
  deadline  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subscription {
  id         String                @id @default(cuid())
  userId     String
  name       String
  icon       String                @default("💳")
  amount     Decimal               @db.Decimal(12, 2)
  currency   String                @default("ARS")
  frequency  SubscriptionFrequency @default(MONTHLY)
  lastUsedAt DateTime?
  active     Boolean               @default(true)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
}

enum SubscriptionFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// ─── Billing & Plans ───────────────────────────────────────────────

enum PlanTier {
  FREE
  PRO
  PREMIUM
}

enum BillingStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

model UserPlan {
  id                  String        @id @default(cuid())
  userId              String        @unique
  tier                PlanTier      @default(FREE)
  status              BillingStatus @default(ACTIVE)
  mercadopagoPreferId String?       @unique
  mercadopagoInitPoin String?       @db.Text
  currentPeriodStart  DateTime      @default(now())
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([userId])
  @@index([status])
}

model Payment {
  id                   String   @id @default(cuid())
  userPlanId           String
  mercadopagoPaymentId String?  @unique
  amount               Decimal  @db.Decimal(12, 2)
  currency             String   @default("ARS")
  status               String   @default("pending") // pending, approved, rejected, refunded
  paymentMethod        String? // credit_card, debit_card, bank_transfer, etc.
  description          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  userPlan UserPlan @relation(fields: [userPlanId], references: [id], onDelete: Cascade)

  @@index([userPlanId, createdAt])
  @@index([mercadopagoPaymentId])
}

// ─── Business Module ───────────────────────────────────────────────

model Client {
  id        String       @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  notes     String?      @db.Text
  status    ClientStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales        Sale[]
  appointments Appointment[]

  @@index([userId, status])
  @@index([userId, name])
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  LEAD
}

model Product {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?  @db.Text
  price       Decimal  @db.Decimal(12, 2)
  cost        Decimal? @db.Decimal(12, 2)
  stock       Int      @default(0)
  minStock    Int      @default(5)
  sku         String?
  category    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales Sale[]

  @@index([userId, active])
  @@index([userId, category])
}

model Sale {
  id          String   @id @default(cuid())
  userId      String
  clientId    String?
  productId   String?
  amount      Decimal  @db.Decimal(12, 2)
  quantity    Int      @default(1)
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, clientId])
}

model Appointment {
  id          String            @id @default(cuid())
  userId      String
  clientId    String?
  title       String
  description String?           @db.Text
  date        DateTime
  duration    Int               @default(60) // minutes
  status      AppointmentStatus @default(SCHEDULED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, status])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ─── Financial Sync Engine ───────────────────────────────────────

model FinancialImport {
  id           String       @id @default(cuid())
  userId       String
  source       String // "mercadopago_csv", "banco_csv", "manual"
  fileName     String?
  fileSize     Int?
  status       ImportStatus @default(PENDING)
  rowsTotal    Int          @default(0)
  rowsImported Int          @default(0)
  rowsSkipped  Int          @default(0)
  dateFrom     DateTime?
  dateTo       DateTime?
  errorMessage String?      @db.Text
  createdAt    DateTime     @default(now())

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries FinancialEntry[]

  @@index([userId, source])
  @@index([userId, createdAt])
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

model FinancialEntry {
  id           String          @id @default(cuid())
  userId       String
  importId     String?
  source       String // "mercadopago", "banco_csv", "manual"
  externalId   String?
  type         TransactionType
  category     String
  subcategory  String?
  amount       Decimal         @db.Decimal(12, 2)
  currency     String          @default("ARS")
  description  String
  counterparty String?
  date         DateTime
  createdAt    DateTime        @default(now())

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  import FinancialImport? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, type])
  @@index([userId, category])
  @@index([userId, source])
}

model BusinessProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  businessName String
  logoUrl      String?
  cuit         String?
  address      String?
  phone        String?
  email        String?
  website      String?
  description  String?  @db.Text
  openingHours String?  @db.Text // JSON: { "mon": "09:00-18:00", ... }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
