generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  avatarUrl     String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  transactions    Transaction[]
  investments     Investment[]
  conversations   Conversation[]
  connections     ProviderConnection[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        TransactionType
  category    String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("ARS")
  description String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, type])
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model Investment {
  id          String           @id @default(cuid())
  userId      String
  name        String
  type        InvestmentType
  symbol      String?
  amount      Decimal          @db.Decimal(12, 2)
  quantity    Decimal?         @db.Decimal(16, 8)
  buyPrice    Decimal          @db.Decimal(12, 2)
  currentPrice Decimal?        @db.Decimal(12, 2)
  currency    String           @default("ARS")
  status      InvestmentStatus @default(ACTIVE)
  notes       String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

enum InvestmentType {
  STOCK
  CRYPTO
  BOND
  FIXED_TERM
  MUTUAL_FUND
  REAL_ESTATE
  OTHER
}

enum InvestmentStatus {
  ACTIVE
  SOLD
  PENDING
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model ProviderConnection {
  id            String           @id @default(cuid())
  userId        String
  providerId    String
  providerType  ProviderType
  label         String
  status        ConnectionStatus @default(PENDING)
  credentials   String           @db.Text
  institutionId String?
  lastSyncAt    DateTime?
  lastError     String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncLogs SyncLog[]

  @@index([userId, providerId])
  @@index([userId, status])
}

enum ProviderType {
  BANK
  BROKER
  CRYPTO
}

enum ConnectionStatus {
  ACTIVE
  PENDING
  ERROR
  EXPIRED
  DISCONNECTED
}

model SyncLog {
  id                    String   @id @default(cuid())
  connectionId          String
  status                SyncStatus
  transactionsImported  Int      @default(0)
  investmentsImported   Int      @default(0)
  accountsImported      Int      @default(0)
  errorMessage          String?  @db.Text
  duration              Int?
  createdAt             DateTime @default(now())

  connection ProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt])
}

enum SyncStatus {
  SUCCESS
  ERROR
  PARTIAL
}
